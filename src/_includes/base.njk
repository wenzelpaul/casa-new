<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <title>{{ title or "Casa Orizzonte Blu" }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description or 'Casa Orizzonte Blu – seaside stay' }}">
  <link rel="stylesheet" href="/assets/css/theme.css">
  <link rel="stylesheet" href="/assets/css/gallery.css">
</head>
<body>
  <header>
    <nav>
      <a href="/">Casa Orizzonte Blu</a>
      <a href="/about/">Über</a>
      <a href="/pictures/">Bilder</a>
      <a href="/calendar/">Kalender</a>
      <a href="/map/">Karte</a>
      <a href="/contact/">Kontakt</a>
      <a href="/impressum/">Impressum</a>
    </nav>
  </header>
  <main>
    {{ content | safe }}
  </main>

  <!-- Lightbox overlay (hidden by default) -->
  <div id="lightbox" aria-hidden="true">
    <button class="lb-close" aria-label="Close">&times;</button>
    <button class="lb-prev" aria-label="Previous">&#10094;</button>
    <figure class="lb-figure">
      <img class="lb-image" alt="">
      <figcaption class="lb-caption"></figcaption>
    </figure>
    <button class="lb-next" aria-label="Next">&#10095;</button>
  </div>

  <script defer src="/assets/js/gallery.js"></script>
</body>
</html>
